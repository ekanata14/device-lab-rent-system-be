generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Printer {
  id              String    @id @default(cuid())
  name            String
  model           String
  status          String    @default("available") // 'available' | 'in-use' | 'broken' | 'buffer'
  endTime         DateTime?
  bufferEndTime   DateTime?
  brokenReason    String?
  currentUser     Json?
  nextReservation Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UsageLog {
  id          String   @id @default(cuid())
  printerId   String
  printerName String
  userName    String
  studentId   String
  usageTime   Int // in minutes
  startTime   DateTime
  endTime     DateTime
  photoUrl    String?  @db.LongText
  stopReason  String?
  statusAtEnd String // 'completed' | 'force-stopped' | 'broken'
  createdAt   DateTime @default(now())
}

model LabSettings {
  id               String   @id @default(cuid())
  isManuallyClosed Boolean  @default(false)
  openTime         String   @default("08:00") // HH:mm
  closeTime        String   @default("17:00") // HH:mm
  updatedAt        DateTime @updatedAt
}
